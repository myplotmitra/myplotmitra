      "dest": "/firebase-messaging-sw.js"
    },
    {
      "src": "/sw.js",
      "headers": {
        "Cache-Control": "no-cache",
        "Service-Worker-Allowed": "/"
      },
      "dest": "/sw.js"
    },
    {
      "src": "/manifest.json",
      "headers": {
        "Content-Type": "application/manifest+json"
      },
      "dest": "/manifest.json"
    },
    {
      "src": "/api/rzp-verify",
      "dest": "/api/rzp-verify.js"
    },
    {
      "src": "/api/rzp-create-order",
      "dest": "/api/rzp-create-order.js"
    },
    {
      "src": "/api/use-credit",
      "dest": "/api/use-credit.js"
    },
    {
      "src": "/api/notify",
      "dest": "/api/notify.js"
    },
    {
      "src": "/_vercel/insights/(.*)",
      "dest": "/_vercel/insights/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
